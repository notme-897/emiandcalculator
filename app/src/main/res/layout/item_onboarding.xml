<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/margin_xlarge"
        android:paddingEnd="@dimen/margin_xlarge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Illustration -->

        <ImageView
            android:id="@+id/imgOnboarding"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginBottom="@dimen/margin_xxlarge"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_launcher_foreground"/>

        <!-- Title -->

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to EMI Calculator"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="28sp"
            android:gravity="center"/>

        <!-- Description -->

        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/screen_padding"
            android:text="Calculate your monthly EMI, total interest and total repayment instantly."
            android:textColor="#CCFFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/margin_tiny"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>