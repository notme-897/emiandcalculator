<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- ================= FIXED HEADER ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/calculatorHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="55dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackContainer"
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="19dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1E293B" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Loan Calculator"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= SCROLLABLE BODY ================= -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewBusinessLoan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/centerBodyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Loan Amount Input Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Requested Loan Capital"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="(₹ Currency)"
                    android:textColor="#1A56E4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <EditText
                android:id="@+id/editTextNumber"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 15,00,000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Loan Amount Quick Select Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:weightSum="5">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAmount5L"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp"
                    android:text="₹5 Lakh"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="10sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="17dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAmount10L"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹10 Lakh"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="10sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="17dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAmount25L"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹25 Lakh"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="10sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="17dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAmount50L"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹50 Lakh"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="10sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="17dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipAmount1Cr"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="34dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:padding="0dp"
                    android:text="₹1 Crore"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="10sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="17dp" />

            </LinearLayout>

            <!-- Processing / Origination Fee & Net Disbursed Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Upfront Processing Fee (% or ₹)"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="(Std 1% - 3%)"
                            android:textColor="#475569"
                            android:textSize="12sp" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/etProcessingFee"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 30,000"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Net Disbursed Cash Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#E8F0FE"
                        android:orientation="horizontal"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Net Cash Disbursed to Bank Account: "
                            android:textColor="#1E293B"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtNetDisbursedDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹14,70,000"
                            android:textColor="#1A56E4"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Repayment Frequency Selector -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Repayment Frequency"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFreqMonthly"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp"
                    android:text="Monthly"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:backgroundTint="#3B99FC"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFreqBiWeekly"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="Bi-Weekly"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFreqWeekly"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="Weekly"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFreqDaily"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:padding="0dp"
                    android:text="Daily"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Interest Rate Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Interest Rate"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="(% Annual)"
                    android:textColor="#1A56E4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <EditText
                android:id="@+id/editTextNumber2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 13.5"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Interest Rate Quick Select Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate10_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="10.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate12_0"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="12.0%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate14_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="14.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate16_0"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="16.0%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- Loan Tenure Section (1 to 10 Years) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/txtLoanTermLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Loan Duration (1 to 10 Yrs)"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loanTermContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/numeric_input_border"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTermValueCombined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 yrs (36 mos)"
                    android:textColor="#1A56E4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtInstallments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="36 installments"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Single Seekbar Row -->
                <ImageView
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_remove"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <SeekBar
                    android:id="@+id/loanSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="16dp"
                    android:max="120"
                    android:progress="36"
                    android:progressTint="#1A56E4"
                    android:thumbTint="#1A56E4"
                    app:layout_constraintEnd_toStartOf="@+id/btnAdd"
                    app:layout_constraintStart_toEndOf="@+id/btnMinus"
                    app:layout_constraintTop_toBottomOf="@+id/txtTermValueCombined" />

                <ImageView
                    android:id="@+id/btnAdd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_add"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMinVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="1 yr"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMaxVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="10 yrs"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Business Term Quick Chips -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:columnCount="3"
                android:rowCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm1Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="1 Yr"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm2Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="2 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm3Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="3 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm5Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="5 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm7Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="7 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBizTerm10Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="10 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </GridLayout>

            <!-- Debt Service Coverage Ratio (DSCR) Integration Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Debt Service Coverage Ratio (DSCR)"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <!-- NOI Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Monthly Net Operating Income (NOI) (₹)"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etOperatingIncome"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 2,50,000"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Existing Debt Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Existing Monthly Debt Payments (₹)"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etExistingBizDebt"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 20,000 (0 if none)"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- DSCR Status Indicator Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#E8F0FE"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DSCR Ratio:"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtDscrRatioDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="1.85"
                                android:textColor="#00C853"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <TextView
                            android:id="@+id/txtDscrStatusNotice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="🟢 DSCR &gt; 1.25: Strong Bank Approval Likelihood"
                            android:textColor="#00C853"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tax Shield & Tax Savings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tax Shield / Tax Savings"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Corporate / Business Tax Bracket (%)"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etTaxRate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 25"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Tax Bracket Chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipTax15"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:padding="0dp"
                            android:text="15%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipTax22"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:padding="0dp"
                            android:text="22%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipTax25"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:padding="0dp"
                            android:text="25%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipTax30"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:padding="0dp"
                            android:text="30%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                    </LinearLayout>

                    <!-- Tax Shield Savings Summary Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#E8F0FE"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Est. Tax Deduction Savings:"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtTaxSavingsDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹85,525"
                                android:textColor="#00C853"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Effective Interest After Tax:"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtEffectiveInterestAfterTaxDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹2,56,575"
                                android:textColor="#1A56E4"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Start Date Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Start Date"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/startDateContainer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/numeric_input_border"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/txtSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22 Jul, 2026"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/imgCalendar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_calendar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#1A56E4" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Calculate Business Loan"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#1A56E4"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="Reset Fields"
                android:textAllCaps="false"
                android:textColor="#1A56E4"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#1A56E4" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
