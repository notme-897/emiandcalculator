<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="vertical">

    <!-- ================= FIXED HEADER ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/calculatorHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="55dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackContainer"
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="19dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1E293B" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Car Loan Calculator"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ================= SCROLLABLE BODY ================= -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewCarLoan"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="40dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/centerBodyLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Vehicle Price, Down Payment & Trade-in Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Price &amp; Down Payment"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Vehicle Price Input -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Vehicle Price (On-Road / Ex-Showroom)"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etVehiclePrice"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 10,00,000"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Down Payment Input -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Down Payment (₹)"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtCarDpPercentDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="(20%)"
                            android:textColor="#1A56E4"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <EditText
                        android:id="@+id/etCarDownPayment"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 2,00,000"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Down Payment Quick Chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="5">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCarDp10"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="2dp"
                            android:padding="0dp"
                            android:text="10%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCarDp15"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:padding="0dp"
                            android:text="15%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCarDp20"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:padding="0dp"
                            android:text="20%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCarDp25"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginHorizontal="2dp"
                            android:padding="0dp"
                            android:text="25%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/chipCarDp30"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="34dp"
                            android:layout_weight="1"
                            android:layout_marginStart="2dp"
                            android:padding="0dp"
                            android:text="30%"
                            android:textAllCaps="false"
                            android:textColor="#1E293B"
                            android:textSize="11sp"
                            app:strokeColor="#CBD5E1"
                            app:cornerRadius="17dp" />

                    </LinearLayout>

                    <!-- Trade-in Value (Optional) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Old Car Trade-in Value (Optional) (₹)"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etTradeInValue"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/numeric_input_border"
                        android:elevation="1dp"
                        android:hint="e.g. 1,00,000 (0 if none)"
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="14dp"
                        android:textColor="#0F172A"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <!-- Net Loan Amount Banner -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="#E8F0FE"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Net Loan Principal:"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtCarNetLoanDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₹7,00,000"
                                android:textColor="#1A56E4"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loan-to-Value (LTV) Ratio:"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtLtvRatioDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="70.0%"
                                android:textColor="#00C853"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Flat Rate vs. Reducing Balance Segmented Toggle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Interest Rate Calculation Method"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRateTypeReducing"
                    style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="Reducing Balance (Std)"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#3B99FC"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRateTypeFlat"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="Flat Rate (Dealer Quote)"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Dealer Flat Rate Warning Card (Shown when Flat Rate is selected) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFlatRateWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFBEB"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#FCD34D"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Dealer Flat Rate Alert"
                        android:textColor="#B45309"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtFlatRateEquivalentDisplay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="A 7.0% Flat Rate costs significantly more! It is equivalent to an Effective ~12.8% Annual Reducing Balance Rate."
                        android:textColor="#78350F"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Loan Amount (Principal Input) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Net Loan Principal"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="(₹ Currency)"
                    android:textColor="#1A56E4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <EditText
                android:id="@+id/editTextNumber"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 7,00,000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Interest Rate Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Interest Rate"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="(% Annual)"
                    android:textColor="#1A56E4"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <EditText
                android:id="@+id/editTextNumber2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 9.0"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Interest Rate Quick Select Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate7_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="7.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate8_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="8.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate9_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="9.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate10_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="10.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- Loan Tenure Section (1 to 7 Years / 12 to 84 Months) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/txtLoanTermLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Loan Duration (1 to 7 Yrs)"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loanTermContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/numeric_input_border"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTermValueCombined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 yrs (60 mos)"
                    android:textColor="#1A56E4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtInstallments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="60 installments"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Single Seekbar Row -->
                <ImageView
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_remove"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <SeekBar
                    android:id="@+id/loanSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="16dp"
                    android:max="84"
                    android:progress="60"
                    android:progressTint="#1A56E4"
                    android:thumbTint="#1A56E4"
                    app:layout_constraintEnd_toStartOf="@+id/btnAdd"
                    app:layout_constraintStart_toEndOf="@+id/btnMinus"
                    app:layout_constraintTop_toBottomOf="@+id/txtTermValueCombined" />

                <ImageView
                    android:id="@+id/btnAdd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_add"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMinVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="1 yr"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMaxVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="7 yrs"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Car Loan Term Quick Select Chips (1Y, 2Y, 3Y, 4Y, 5Y, 7Y) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:columnCount="3"
                android:rowCount="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm1Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="1 Yr"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm2Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="2 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm3Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="3 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm4Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="4 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm5Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="5 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipCarTerm7Y"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="2dp"
                    android:padding="0dp"
                    android:text="7 Yrs"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </GridLayout>

            <!-- Processing / Documentation Fees (Optional) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Processing / Documentation Fees (Optional) (₹)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etProcessingFee"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 5,000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Start Date Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Start Date"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/startDateContainer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/numeric_input_border"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/txtSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22 Jul, 2026"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/imgCalendar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_calendar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#1A56E4" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Vehicle Depreciation & Equity Analysis Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDepreciationAnalysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#F8FAFC"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Vehicle Depreciation &amp; Ownership Cost"
                        android:textColor="#0F172A"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Cost of Ownership:"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtTotalOwnershipCostDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹11,68,400"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Est. Car Value (Year 3):"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtYear3CarValueDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹5,78,000"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/txtEquityStatusNotice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="✅ Positive Equity: Loan balance stays below market car value."
                        android:textColor="#00C853"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Calculate Car Loan EMI"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#1A56E4"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="Reset Fields"
                android:textAllCaps="false"
                android:textColor="#1A56E4"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#1A56E4" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
