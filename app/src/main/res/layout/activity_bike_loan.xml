<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB"
    android:orientation="vertical">

    <!-- ================= FIXED HEADER ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/calculatorHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="55dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackContainer"
            android:layout_width="38dp"
            android:layout_height="38dp"
            app:cardBackgroundColor="#F1F5F9"
            app:cardCornerRadius="19dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="#1E293B" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Two-Wheeler / Bike Loan Calculator"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollViewBikeLoan"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="36dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingTop="12dp">

            <!-- Pricing Mode Toggle (Ex-Showroom vs On-Road) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPriceOnRoad"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="On-Road Price"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPriceExShowroom"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Ex-Showroom Price"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Bike Price Input -->
            <TextView
                android:id="@+id/txtBikePriceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="On-Road Bike Price (₹)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etBikePrice"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 1,20,000"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Price Quick Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="5">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPrice80k"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="2dp"
                    android:padding="0dp"
                    android:text="₹80k"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPrice120k"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹1.2L"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPrice180k"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹1.8L"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPrice250k"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="₹2.5L"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipPrice400k"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="2dp"
                    android:padding="0dp"
                    android:text="₹4.0L"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- Down Payment Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Down Payment (₹)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etDownPayment"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 24,000 (20%)"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Down Payment Quick % Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipDp0"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="0% (Zero DP)"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipDp10"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="10% DP"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipDp20"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="20% DP"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipDp30"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="30% DP"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- Upfront Processing & Registration Fees -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Processing &amp; Hypothecation Charges (₹)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etProcessingFee"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 1,500"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Net Loan & Ownership Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Net Loan Principal Financed:"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtNetLoanDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹96,000"
                            android:textColor="#1A56E4"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Out-of-Pocket Ownership Cost:"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtTotalOwnershipCostDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹1,38,500"
                            android:textColor="#1E293B"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Interest Rate Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Interest Rate (% per annum)"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editTextNumber2"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/numeric_input_border"
                android:elevation="2dp"
                android:hint="e.g. 11.5"
                android:inputType="numberDecimal"
                android:paddingHorizontal="16dp"
                android:textColor="#0F172A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- Interest Rate Quick Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate9_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="9.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate11_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="11.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate13_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="13.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipRate15_5"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="15.5%"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- Loan Tenure Section (12 to 48 Months / 1 to 4 Years) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/txtLoanTermLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Loan Duration (12 to 48 Mos)"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loanTermContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/numeric_input_border"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtTermValueCombined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="36 mos (3 yrs)"
                    android:textColor="#1A56E4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/txtInstallments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="36 EMIs"
                    android:textColor="#475569"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Single Seekbar Row -->
                <ImageView
                    android:id="@+id/btnMinus"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_remove"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <SeekBar
                    android:id="@+id/loanSeekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="16dp"
                    android:max="48"
                    android:progress="36"
                    android:progressTint="#1A56E4"
                    android:thumbTint="#1A56E4"
                    app:layout_constraintEnd_toStartOf="@+id/btnAdd"
                    app:layout_constraintStart_toEndOf="@+id/btnMinus"
                    app:layout_constraintTop_toBottomOf="@+id/txtTermValueCombined" />

                <ImageView
                    android:id="@+id/btnAdd"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/button_outline"
                    android:padding="8dp"
                    android:src="@drawable/ic_add"
                    app:layout_constraintBottom_toBottomOf="@+id/loanSeekBar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMinVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="12 mos"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

                <TextView
                    android:id="@+id/txtMaxVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="48 mos"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="@+id/loanSeekBar"
                    app:layout_constraintTop_toBottomOf="@+id/loanSeekBar" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Tenure Quick Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal"
                android:weightSum="4">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBikeTerm12M"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:padding="0dp"
                    android:text="12 Mos"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBikeTerm24M"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="24 Mos"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBikeTerm36M"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    android:padding="0dp"
                    android:text="36 Mos"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/chipBikeTerm48M"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:padding="0dp"
                    android:text="48 Mos"
                    android:textAllCaps="false"
                    android:textColor="#1E293B"
                    android:textSize="11sp"
                    app:strokeColor="#CBD5E1"
                    app:cornerRadius="18dp" />

            </LinearLayout>

            <!-- EV Scooter / Fuel Savings vs EMI Offset Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#ECFDF5"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#A7F3D0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EV Scooter / Bike Fuel Savings vs EMI Offset"
                        android:textColor="#065F46"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Est. Monthly Petrol Cost Saved:"
                            android:textColor="#047857"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtEvSavingsDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹2,200 / mo"
                            android:textColor="#059669"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Net Effective Monthly Bike EMI:"
                            android:textColor="#047857"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/txtNetEffectiveEmiDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="₹980 / mo"
                            android:textColor="#065F46"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Start Date Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Purchase Date"
                android:textColor="#0F172A"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/startDateContainer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/numeric_input_border"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp">

                <TextView
                    android:id="@+id/txtSelectedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24 Jul, 2026"
                    android:textColor="#0F172A"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/imgCalendar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_calendar"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#1A56E4" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Action Buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCalculate"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Calculate Bike Loan EMI"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="#1A56E4"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="Reset Fields"
                android:textAllCaps="false"
                android:textColor="#1A56E4"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:strokeColor="#1A56E4" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
