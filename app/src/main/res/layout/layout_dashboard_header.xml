<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardHeader"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@drawable/header_background">

    <!-- Background Decoration -->
    <ImageView
        android:id="@+id/imgHeaderDecoration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:alpha="0.15"
        app:srcCompat="@drawable/circle_overlay" />

    <!-- Header Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/margin_large"
        android:paddingTop="@dimen/margin_xxlarge"
        android:paddingEnd="@dimen/margin_large"
        android:paddingBottom="@dimen/margin_large">

        <TextView
            android:id="@+id/txtGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good Morning"
            android:textColor="#E3F2FD"
            android:textSize="16sp"
            android:textStyle="normal" />

        <TextView
            android:id="@+id/txtDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:text="Tuesday, Jul 15"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_large"
            android:text="EMI Calculator"
            android:textColor="#FFFFFF"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtHeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:text="Smart Loan Finance Calculator"
            android:textColor="#EAF6FF"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>