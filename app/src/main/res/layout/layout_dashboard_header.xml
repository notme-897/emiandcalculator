<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/dashboardHeader"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/header_background">

    <!-- Background Decoration -->
    <ImageView
        android:id="@+id/imgHeaderDecoration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:alpha="0.15"
        app:srcCompat="@drawable/circle_overlay" />

    <!-- Rich Header Content -->
    <LinearLayout
        android:id="@+id/headerContentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="36dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <!-- Top Bar: Greeting on left, Date on right -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="Good Morning"
                android:textColor="#E3F2FD"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txtDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="Wed, Jul 22"
                android:textColor="#E3F2FD"
                android:textSize="13sp" />

        </RelativeLayout>

        <!-- Main Title -->
        <TextView
            android:id="@+id/txtHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="EMI Calculator"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/txtHeaderSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Smart Finance Hub"
            android:textColor="#EAF6FF"
            android:textSize="13sp" />

    </LinearLayout>

</FrameLayout>