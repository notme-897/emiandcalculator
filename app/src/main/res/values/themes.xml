<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme with transparent system bars for immersive edge-to-edge full screen -->
    <style name="Base.Theme.Calculatoremi" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Calculatoremi" parent="Base.Theme.Calculatoremi" />

    <!-- 20x Enhanced Bottom Navigation Active Indicator Pill -->
    <style name="CustomActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#E8F0FE</item>
    </style>

    <!-- 20x Enhanced Bottom Navigation Text Styles -->
    <style name="BottomNavActiveText">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#1A56E4</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavInactiveText">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#64748B</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>